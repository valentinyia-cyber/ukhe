file /var/folders/ch/kb7x45ys2fq6dcpfs379ph280000gp/T//St18749.000001 saved
    as .dta format

. 
. capture program drop import_hesa_csv

. program define import_hesa_csv
  1.     syntax using/, TABLE(integer) SHORTNAME(string) [FILTER]
  2. 
.     local headerrow 0
  3.     local lineno 0
  4.     file open hesa_fh using "`using'", read text
  5.     file read hesa_fh line
  6.     while r(eof) == 0 {
  7.         local lineno = `lineno' + 1
  8.         if strpos(`"`line'"', "UKPRN,") == 1 | strpos(`"`line'"', "Categor
> y marker,") == 1 {
  9.             local headerrow `lineno'
 10.             continue, break
 11.         }
 12.         file read hesa_fh line
 13.     }
 14.     file close hesa_fh
 15. 
.     if `headerrow' == 0 {
 16.         di as error "Could not find a HESA header row in `using'"
 17.         exit 459
 18.     }
 19. 
.     import delimited using "`using'", varnames(`headerrow') stringcols(_all) 
> clear ///
>         bindquote(strict) encoding("UTF-8")
 20. 
.     foreach v in number value value000s value_000s valueratio value_ratio num
> bervalue number_value {
 21.         capture confirm string variable `v'
 22.         if !_rc {
 23.             quietly replace `v' = ustrtrim(itrim(`v'))
 24.             quietly replace `v' = "" if `v' == "."
 25.             quietly replace `v' = "-" + regexs(1) if regexm(`v', "^\(([0-9
> ][0-9,]*\.?[0-9]*)\)$")
 26.             capture destring `v', replace ignore(",")
 27.         }
 28.     }
 29. 
.     local academic_year_var ""
 30.     foreach v in academicyear academiyear academic_year {
 31.         capture confirm variable `v'
 32.         if !_rc & "`academic_year_var'" == "" {
 33.             local academic_year_var "`v'"
 34.         }
 35.     }
 36.     if "`academic_year_var'" != "" {
 37.         capture confirm string variable `academic_year_var'
 38.         if !_rc {
 39.             quietly replace `academic_year_var' = ustrtrim(itrim(`academic
> _year_var'))
 40.         }
 41.         gen int year = real(substr(`academic_year_var', 1, 4))
 42.         label variable year "Academic year start year"
 43.     }
 44. 
.     gen int hesa_table = `table'
 45.     gen str40 hesa_short_name = "`shortname'"
 46.     local source_file "`using'"
 47.     local csv_prefix "$hesa_csv_dir/"
 48.     local prefix_len = strlen("`csv_prefix'")
 49.     if substr("`source_file'", 1, `prefix_len') == "`csv_prefix'" {
 50.         local source_file = "csv/" + substr("`source_file'", `prefix_len' 
> + 1, .)
 51.     }
 52.     gen strL hesa_source_file = "`source_file'"
 53. 
.     capture confirm variable ukprn
 54.     if !_rc {
 55.         capture confirm string variable ukprn
 56.         if !_rc {
 57.             quietly replace ukprn = ustrtrim(itrim(ukprn))
 58.             destring ukprn, replace ignore(",") force
 59.         }
 60. 
.         merge m:1 ukprn using "$ref2021_multi_uoa_file", keep(match) nogen
 61.         gen byte ref2021_filter_applied = 1
 62.         label variable ref2021_filter_applied "Rows restricted to REF2021 
> institutions with >1 UoA"
 63.     }
 64.     else {
 65.         gen byte ref2021_filter_applied = 0
 66.         label variable ref2021_filter_applied "No UKPRN in source CSV; REF
> 2021 filter not applied"
 67.         di as error "Warning: no UKPRN column in `using'; saved without RE
> F2021 provider filtering."
 68.     }
 69. 
.     capture order ukprn ref2021_institution_name n_ref2021_uoas
 70.     order hesa_table hesa_short_name hesa_source_file ref2021_filter_appli
> ed, last
 71.     compress
 72. end

. 
. local tables "1 6 7 8 11 12 13 14"

. 
. local short_1  "students"

. local short_6  "tuition_fees"

. local short_7  "income"

. local short_8  "expenditure"

. local short_11 "staff_fte"

. local short_12 "staff_costs"

. local short_13 "severance"

. local short_14 "kfi"

. 
. local sort_1  "ukprn levelofstudy modeofstudy categorymarker category year"

. local sort_6  "ukprn tuitionfeesandeducationcontracts v9 year"

. local sort_7  "ukprn categorymarker category year"

. local sort_8  "ukprn hesacostcentre academicdepartments activity year"

. local sort_11 "ukprn contractmarker categorymarker category year"

. local sort_12 "ukprn staffcosts unit year"

. local sort_13 "ukprn categorymarker category year"

. local sort_14 "ukprn kfiratiotitle year"

. 
. local order_1  "modeofstudy categorymarker category year"

. local order_6  "year"

. local order_7  "year"

. local order_8  "year"

. local order_11 "year"

. local order_12 "staffcosts unit year"

. local order_13 "categorymarker category year"

. local order_14 "kfiratiotitle year"

. 
. local value_source_1  "number"

. local value_source_6  "value000s"

. local value_source_7  "value000s"

. local value_source_8  "value000s"

. local value_source_11 "number"

. local value_source_12 "numbervalue"

. local value_source_13 "value000s"

. local value_source_14 "valueratio"

. 
. foreach t of local tables {
  2.     local short "`short_`t''"
  3.     local table_id : display %02.0f `t'
  4. 
.     if inlist(`t', 1, 8, 11) {
  5.         local table_dir "`csv_dir'/table-`t'"
  6.         local files : dir "`table_dir'" files "*.csv"
  7.     }
  8.     else {
  9.         local table_dir "`csv_dir'"
 10.         local files "table-`t'.csv"
 11.     }
 12. 
.     local first 1
 13.     tempfile combined
 14. 
.     foreach f of local files {
 15.         local csv_path "`table_dir'/`f'"
 16.         di as text "Importing HESA table `t': `csv_path'"
 17.         quietly import_hesa_csv using "`csv_path'", table(`t') shortname("
> `short'") filter
 18. 
.         if `first' {
 19.             save "`combined'", replace
 20.             local first 0
 21.         }
 22.         else {
 23.             append using "`combined'"
 24.             save "`combined'", replace
 25.         }
 26.     }
 27. 
.     if `first' {
 28.         di as error "No CSV files found for HESA table `t'"
 29.         continue
 30.     }
 31. 
.     use "`combined'", clear
 32.     local value_source "`value_source_`t''"
 33.     capture confirm variable `value_source'
 34.     if !_rc {
 35.         rename `value_source' value
 36.     }
 37.     else {
 38.         local allvars : varlist _all
 39.         local has_value : list posof "value" in allvars
 40.         if !`has_value' {
 41.             di as error "Expected value source variable `value_source' for
>  HESA table `t'"
 42.             exit 111
 43.         }
 44.     }
 45.     label variable value "Value"
 46. 
.     foreach v of local sort_`t' {
 47.         capture confirm variable `v'
 48.         if _rc {
 49.             di as error "Expected sort variable `v' for HESA table `t'"
 50.             exit 111
 51.         }
 52.     }
 53. 
.     order `order_`t'', before(academicyear)
 54.     sort `sort_`t''
 55.     label data "HESA table `t' (`short'), converted from CSV"
 56.     save "`out_dir'/T`table_id'_`short'.dta", replace
 57. 
.     count
 58.     di as result "Saved `r(N)' rows: `out_dir'/T`table_id'_`short'.dta"
 59. }
